{
    "i18n": true,
    "type": "tabs",
    "items": {
        "account": {
            "type": "panel",
            "label": "account",
            "items": {
                "email": {
                    "type": "text",
                    "label": "email",
                    "newLine": true
                },
                "password": {
                    "type": "password",
                    "label": "password",
                    "newLine": true
                }
            }
        },
        "python": {
            "type": "panel",
            "label": "python",
            "items": {
                "pythonExecutable": {
                    "type": "text",
                    "label": "pythonExecutable",
                    "newLine": true,
                    "placeholder": "pythonExecutablePlaceholder"
                },
                "bootstrapOnStart": {
                    "type": "checkbox",
                    "label": "bootstrapOnStart",
                    "newLine": true
                },
                "installHintHeader": {
                    "type": "staticText",
                    "text": "installHintHeader",
                    "newLine": true,
                    "style": { "fontWeight": "bold", "marginTop": "16px" }
                },
                "installHintLinux": {
                    "type": "staticText",
                    "text": "installHintLinux",
                    "newLine": true
                },
                "installCmdLinux": {
                    "type": "text",
                    "newLine": true,
                    "disabled": true,
                    "label": "installCmdLinuxLabel",
                    "defaultFunc": "return 'sudo apt install python3.13 python3.13-venv python3.13-distutils python3-setuptools'",
                    "noTranslation": true,
                    "style": { "fontFamily": "monospace" }
                },
                "installHintVerify": {
                    "type": "staticText",
                    "text": "installHintVerify",
                    "newLine": true,
                    "style": { "marginTop": "8px" }
                },
                "installCmdVerify": {
                    "type": "text",
                    "newLine": true,
                    "disabled": true,
                    "label": "installCmdVerifyLabel",
                    "defaultFunc": "return 'python3.13 --version'",
                    "noTranslation": true,
                    "style": { "fontFamily": "monospace" }
                }
            }
        },
        "advanced": {
            "type": "panel",
            "label": "advanced",
            "items": {
                "sidecarLogLevel": {
                    "type": "select",
                    "label": "sidecarLogLevel",
                    "newLine": true,
                    "options": [
                        { "value": "info",    "label": "logInfo" },
                        { "value": "debug",   "label": "logDebug" },
                        { "value": "warning", "label": "logWarning" },
                        { "value": "error",   "label": "logError" }
                    ]
                }
            }
        }
    }
}
