{
  "name": "iobroker.mammotion-pymammotion",
  "version": "0.1.3",
  "description": "ioBroker adapter for Mammotion devices using a PyMammotion sidecar",
  "author": {
    "name": "DNAngel",
    "email": "stolly82@web.de"
  },
  "homepage": "https://github.com/DNAngelX/ioBroker.mammotion.pymammotion",
  "license": "GPL-3.0-only",
  "keywords": [
    "ioBroker",
    "Mammotion",
    "PyMammotion",
    "Luba",
    "Yuka",
    "cloud",
    "mqtt"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DNAngelX/ioBroker.mammotion.pymammotion.git"
  },
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/dev-server": "^0.8.0",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node20": "^20.1.9",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "chai": "^4.5.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "mocha": "^11.7.5",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "main": "build/main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "build/",
    "docs/",
    "python-daemon/",
    "scripts/",
    "io-package.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rimraf build",
    "build": "build-adapter ts",
    "watch": "build-adapter ts --watch",
    "prebuild:ts": "rimraf build",
    "build:ts": "build-adapter ts",
    "watch:ts": "build-adapter ts --watch",
    "test:ts": "mocha --config test/mocharc.custom.json \"src/*.test.ts\" \"src/**/*.test.ts\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:ts && npm run test:package",
    "check": "tsc --noEmit",
    "lint": "eslint --ext .ts src/",
    "python:check": "./scripts/python/check-python.sh",
    "python:install:macos": "./scripts/python/install-macos.sh",
    "python:install:linux": "./scripts/python/install-linux.sh",
    "translate": "translate-adapter",
    "release": "release-script",
    "dev-server": "dev-server --temp /tmp/iobroker-mammotion-pymammotion-devserver"
  },
  "bugs": {
    "url": "https://github.com/DNAngelX/ioBroker.mammotion.pymammotion/issues"
  },
  "readmeFilename": "README.md"
}
